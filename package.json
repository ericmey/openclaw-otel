{
  "name": "openclaw-otel",
  "version": "1.0.0",
  "description": "OpenTelemetry exporter for OpenClaw — ships diagnostic events as OTel logs, metrics, and traces with field shapes that work cleanly in Grafana / LGTM stacks.",
  "license": "MIT",
  "author": "Eric Mey <ericmey@gmail.com>",
  "homepage": "https://github.com/ericmey/openclaw-otel#readme",
  "bugs": {
    "url": "https://github.com/ericmey/openclaw-otel/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericmey/openclaw-otel.git"
  },
  "keywords": [
    "openclaw",
    "opentelemetry",
    "otel",
    "observability",
    "grafana",
    "loki",
    "tempo",
    "mimir",
    "lgtm",
    "exporter",
    "plugin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.217.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.217.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "openclaw-otel",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.2"
    },
    "compat": {
      "pluginApi": ">=2026.5.4"
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": true
    },
    "build": {
      "openclawVersion": "2026.5.4"
    }
  },
  "overrides": {
    "uuid": "^14"
  }
}
