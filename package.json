{
  "name": "openclaw-otel",
  "version": "0.1.0",
  "description": "OpenTelemetry exporter for OpenClaw — ships diagnostic events as OTel logs, metrics, and traces with field shapes that work cleanly in Grafana / LGTM stacks.",
  "license": "MIT",
  "author": "Eric Mey <2865140+ericmey@users.noreply.github.com>",
  "homepage": "https://github.com/ericmey/openclaw-otel#readme",
  "bugs": {
    "url": "https://github.com/ericmey/openclaw-otel/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericmey/openclaw-otel.git"
  },
  "keywords": [
    "openclaw",
    "opentelemetry",
    "otel",
    "observability",
    "grafana",
    "loki",
    "tempo",
    "mimir",
    "lgtm",
    "exporter",
    "plugin"
  ],
  "type": "module",
  "main": "./index.ts",
  "files": [
    "index.ts",
    "api.ts",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.216.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.216.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.216.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "openclaw-otel",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.3"
    },
    "compat": {
      "pluginApi": ">=2026.5.2"
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": false
    }
  }
}
